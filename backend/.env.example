# Server
PORT=4000
NODE_ENV=development

# CORS - frontend origin (có thể nhiều origin, cách nhau bằng dấu phẩy)
CORS_ORIGIN=http://localhost:5173

# URL công khai dùng cho link trong email (reset password).
# Trống = lấy origin đầu tiên từ CORS_ORIGIN
# Nếu deploy hoặc test trên LAN: http://192.168.1.10:5173
PUBLIC_URL=

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=viqitech

# JWT
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Gemini AI (chatbot) - lấy key miễn phí tại: https://aistudio.google.com/apikey
# Để trống = chatbot dùng rule keyword fallback
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# SMTP gửi email (chức năng quên mật khẩu)
# Gmail: bật 2FA → tạo App Password tại https://myaccount.google.com/apppasswords
# Để trống = email không gửi, hiển thị link demo trên UI
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=ViQiTech
SMTP_FROM_EMAIL=

# Admin seed (chạy npm run seed sẽ tạo / cập nhật admin này)
ADMIN_EMAIL=admin@viqitech.vn
ADMIN_PASSWORD=admin123
ADMIN_NAME=Quản trị viên
